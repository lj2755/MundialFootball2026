{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "🚀 Lanzar Todo (pipeline + dashboard)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "args": [],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "📊 Solo Dashboard (Streamlit)",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}/dashboard/app.py",
        "--server.port=8501",
        "--server.headless=false"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "⚙️ Solo Pipeline (datos + IA)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "args": ["--pipeline-only"],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "🌐 Webhook Server",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/execution_layer/webhook_server.py",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "🧪 Tests",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": [
        "tests/",
        "-v",
        "--tb=short"
      ],
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "🔍 Debug Pipeline (un ciclo)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/processing_layer/pipeline.py",
      "env": {
        "PYTHONPATH": "${workspaceFolder}"
      },
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "🏟️ Full Stack (webhook + pipeline + dashboard)",
      "configurations": [
        "🌐 Webhook Server",
        "⚙️ Solo Pipeline (datos + IA)",
        "📊 Solo Dashboard (Streamlit)"
      ],
      "stopAll": true
    }
  ]
}
