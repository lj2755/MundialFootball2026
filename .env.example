# ── Copia este archivo como .env y rellena tus valores ──────────────────────

# Anthropic — para el análisis de IA
ANTHROPIC_API_KEY=sk-ant-...

# NewsAPI.org — gratis para 100 req/día, suficiente para desarrollo
# Regístrate en https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Polygon RPC — puedes usar el público o Alchemy/Infura para más fiabilidad
POLYGON_RPC_URL=https://polygon-rpc.com

# Ejecución — "manual" (recomendado) o "auto" (requiere private key)
EXECUTION_MODE=manual

# Edge mínimo para auto-ejecución (solo si EXECUTION_MODE=auto)
AUTO_THRESHOLD=0.08

# SOLO si EXECUTION_MODE=auto — guarda esto con extremo cuidado
# NUNCA subas esta línea a git
# WALLET_PRIVATE_KEY=0x...

# Puerto del webhook interno
WEBHOOK_PORT=8765

# The Odds API (opcional, como fallback de precios si Polymarket no tiene el partido)
# ODDS_API_KEY=your_odds_api_key_here
